rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =====================================
    // HELPER FUNCTIONS
    // =====================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is the document owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Get user's profile data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Check user role
    function hasRole(role) {
      let data = getUserData();
      return isAuthenticated() && (
        (data.roles != null && role in data.roles) || 
        (data.role == role)
      );
    }
    
    // Check if user is approved
    function isApproved() {
      return isAuthenticated() && getUserData().accountStatus == 'approved';
    }
    
    // Check if user is a manager
    function isManager() {
      return hasRole('manager') && isApproved();
    }
    
    // Check if user is a driver
    function isDriver() {
      return hasRole('driver') && isApproved();
    }
    
    // Check if user is a student
    function isStudent() {
      return hasRole('student') && isApproved();
    }
    
    // Check if driver is assigned to a specific ride
    function isAssignedDriver(rideId) {
      return isDriver() && get(/databases/$(database)/documents/rides/$(rideId)).data.driverId == request.auth.uid;
    }
    
    // =====================================
    // USERS COLLECTION
    // =====================================
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for display purposes)
      allow read: if isAuthenticated();
      
      // Users can create their own profile during registration
      allow create: if isOwner(userId);
      
      // Users can update their own profile
      // Managers can update any user (for approval/rejection)
      allow update: if isOwner(userId) || isManager();
      
      // Only managers can delete users
      allow delete: if isManager();
    }
    
    // =====================================
    // STUDENTS COLLECTION
    // =====================================
    match /students/{studentId} {
      // Authenticated users can read student data
      allow read: if isAuthenticated();
      
      // Students can create their own record
      allow create: if isOwner(studentId);
      
      // Students can update their own record
      // Drivers can update assigned students
      // Managers can update any student
      allow update: if isOwner(studentId) || isManager() || 
        (isDriver() && isAssignedDriver(resource.data.currentRideId));
      
      // Only managers can delete
      allow delete: if isManager();
    }
    
    // =====================================
    // DRIVERS COLLECTION
    // =====================================
    match /drivers/{driverId} {
      // Authenticated users can read driver data
      allow read: if isAuthenticated();
      
      // Drivers can create their own record
      allow create: if isOwner(driverId);
      
      // Drivers can update their own record
      // Managers can update any driver
      allow update: if isOwner(driverId) || isManager();
      
      // Only managers can delete
      allow delete: if isManager();
    }
    
    // =====================================
    // RIDES COLLECTION
    // =====================================
    match /rides/{rideId} {
      // Students can read their own rides (by studentId field)
      // Drivers can read rides assigned to them
      // Managers can read all rides
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isManager()
      );
      
      // List queries - authenticated users with approved status
      allow list: if isApproved();
      
      // Students can create ride requests
      // Drivers and managers can also create rides
      allow create: if isStudent() || isDriver() || isManager();
      
      // Managers can update any ride
      // Drivers can update rides assigned to them
      // Students can update their own ride requests (e.g., cancel)
      allow update: if isManager() || 
        (isDriver() && resource.data.driverId == request.auth.uid) ||
        (isStudent() && resource.data.studentId == request.auth.uid);
      
      // Only managers can delete rides
      allow delete: if isManager();
    }
    
    // =====================================
    // STATISTICS COLLECTION
    // =====================================
    match /statistics/{eventDate} {
      // Managers can read/write statistics
      // Others cannot access
      allow read: if isManager();
      allow write: if isManager();
    }
    
    // =====================================
    // SYSTEM COLLECTION
    // =====================================
    match /system/{docId} {
      // All authenticated users can read system settings
      allow read: if isAuthenticated();
      
      // Only managers can write
      allow write: if isManager();
    }
    
    // =====================================
    // NOTIFICATIONS COLLECTION
    // =====================================
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // System/managers can create notifications
      allow create: if isManager();
      
      // Users can update their notifications (mark as read)
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can delete their notifications
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // =====================================
    // CARS COLLECTION
    // =====================================
    match /cars/{carId} {
      // Authenticated users can read car data
      allow read: if isAuthenticated();
      
      // Only managers can create cars
      allow create: if isManager();
      
      // Managers can update any car, drivers can update for assignment/release
      allow update: if isManager() || isDriver();
      
      // Only managers can delete cars
      allow delete: if isManager();
    }
    
    // =====================================
    // WEEKLY ATTENDANCE COLLECTION
    // =====================================
    match /weeklyAttendance/{weekId} {
      allow read: if isAuthenticated();
      
      match /responses/{userId} {
        // Users can read and write their own response
        allow read: if isOwner(userId) || isManager();
        allow write: if isOwner(userId) || isManager();
      }
    }
    // =====================================
    // SETTINGS COLLECTION (Sabha location, etc.)
    // =====================================
    match /settings/{settingId} {
      // All authenticated users can read settings
      allow read: if isAuthenticated();
      
      // Only managers can update settings
      allow write: if isManager();
    }
  }
}
